# Скопируйте в backend/.env и заполните. В git — только .env.example.
# POSTGRES_* должны совпадать с корневым .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me            # openssl rand -base64 48
DJANGO_SETTINGS_MODULE=config.settings.prod   # ПРОД: prod, НЕ dev
DJANGO_ALLOWED_HOSTS=SERVER_IP         # фаза 2: замените на домен
DJANGO_ENABLE_TLS=False                # фаза 1: False | фаза 2: True

# --- PostgreSQL (совпадает с корневым .env) ---
POSTGRES_DB=koncboom
POSTGRES_USER=koncboom
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS (same-origin ⇒ фактически не задействован, держим корректным) ---
CORS_ALLOWED_ORIGINS=http://SERVER_IP  # фаза 2: https://ваш-домен

# Для локальной dev-разработки:
#   DJANGO_SETTINGS_MODULE=config.settings.dev
#   DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1