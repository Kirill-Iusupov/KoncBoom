# Скопируйте в .env и заполните реальными значениями.
# .env в git НЕ коммитится (см. .gitignore), только .env.example.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=koncboom
POSTGRES_USER=koncboom
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS: только origin фронта, никогда '*' ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
