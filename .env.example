# Корневой .env — читается docker-compose (db, redis, build-arg frontend).
# POSTGRES_* ДОЛЖНЫ совпадать с backend/.env, иначе Django не подключится к БД.
POSTGRES_DB=koncboom
POSTGRES_USER=koncboom
POSTGRES_PASSWORD=change-me-strong-password

# Фронт ходит на относительный /api ⇒ этот build-arg на запросы не влияет.
# НЕ ставьте сюда "/api": next.config.ts делает new URL(...) и упадёт на билде.
NEXT_PUBLIC_API_URL=http://localhost/api